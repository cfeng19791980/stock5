            pct_val = round((close_val - prev_close_val) / prev_close_val * 100, 2)

        # 记录预测
        action = 'buy' if score >= 60 else ('sell' if score < 40 else 'hold')
        log_prediction(conn, code, score, action, close_val)
        
        stocks_analysis.append({
            'code': code,
            'name': name,
            'score': score,
            'close': round(close_val, 2),
            'pct_chg': pct_val,
            'volume': int(latest['volume']) if pd.notna(latest['volume']) else 0,
            'date': str(latest['date']),
            'advice': f"评分{score}分。{'建议买入' if score >= 60 else ('建议卖出' if score < 40 else '持有观望')}",
            'buy_signal': score >= 60,
            'sell_signal': score < 40,
            'features_count': len(feat),
        })
    except:
        continue

conn.close()

