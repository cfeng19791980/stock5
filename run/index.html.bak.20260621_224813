            html += '<div class="strategy-section"><div class="strategy-section-title"><i class="fas fa-box"></i> 持仓分析</div>';
            holdings.forEach(h => {
                var ac = h.action==='sell_all'||h.action==='sell_half'?'var(--danger)':h.action==='add_position'?'var(--success)':h.action==='sell_suggest'?'var(--warning)':'var(--text-muted)';
                var at = {sell_all:'全部卖出',sell_half:'卖出一半',sell_suggest:'建议卖出',add_position:'建议加仓',hold:'持有'}[h.action]||h.action;
                var pc = h.pnl_pct>=0?'var(--success)':'var(--danger)';
                html += '<div class="strategy-item"><span class="code">'+h.code+'</span><span class="name">'+h.name+'</span><span style="font-size:10px;color:'+pc+';margin-right:6px;">'+(h.pnl_pct>=0?'+':'')+h.pnl_pct+'%</span><span class="score" style="background:'+(h.score>=70?'var(--success)':h.score>=50?'var(--warning)':'var(--danger)')+';color:#fff;font-size:11px;padding:2px 6px;border-radius:4px;">'+Math.round(h.score)+'</span><span class="signal-badge" style="background:'+ac+';color:#fff;font-size:10px;">'+at+'</span>'+(h.sell_shares?'<span style="font-size:10px;color:var(--danger);margin-left:4px;">'+h.sell_shares+'股</span>':'')+'</div>';
            });
            html += '</div>';
        }
        // 买入信号
        if (buySignals.length > 0) {
            html += '<div class="strategy-section"><div class="strategy-section-title"><i class="fas fa-arrow-trend-up"></i> 买入信号 ('+summary.slots_available+'个空位)</div>';
            buySignals.forEach(b => {
                var sc = b.signal==='strong_buy'?'var(--success)':'var(--primary)';
                html += '<div class="strategy-item"><span class="code">'+b.code+'</span><span class="name">'+b.name+'</span><span class="score" style="background:'+sc+';color:#fff;font-size:11px;padding:2px 6px;border-radius:4px;">'+b.score+'</span><span class="signal-badge" style="background:'+sc+';color:#fff;font-size:10px;">'+(b.signal==='strong_buy'?'强烈买入':'买入')+'</span><span style="font-size:10px;color:var(--text-muted);margin-left:4px;">'+b.suggested_shares+'股 ¥'+(b.suggested_amount/10000).toFixed(1)+'万</span></div>';
            });
            html += '</div>';
        }
        // 汇总
        html += '<div style="display:flex;gap:8px;margin-top:4px;font-size:10px;color:var(--text-muted);">';
        html += '<span>建议卖出: ¥'+(summary.total_sell_amount/10000).toFixed(2)+'万</span>';
        html += '<span>建议买入: ¥'+(summary.total_buy_amount/10000).toFixed(2)+'万</span>';
