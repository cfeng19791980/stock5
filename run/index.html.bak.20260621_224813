    function renderMinute(predictions) {
        const tbody = document.getElementById('body-minute');
        document.getElementById('loading').style.display = 'none';

        if (!predictions || predictions.length === 0) {
            tbody.innerHTML = '<tr><td colspan="10"><div class="empty-state"><i class="fas fa-inbox"></i><p>暂无数据</p></div></td></tr>';
            document.getElementById('minute-pager').innerHTML = '';
            return;
        }

        predictions = [...predictions].sort((a,b) => b.score - a.score);
        const perPage = 10;
        const total = predictions.length;
        const totalPages = Math.ceil(total / perPage);
        let currentPage = parseInt(sessionStorage.getItem('minute_page') || '1', 10);
        if (currentPage < 1) currentPage = 1;
        if (currentPage > totalPages) currentPage = totalPages;

        const start = (currentPage - 1) * perPage;
        const pageItems = predictions.slice(start, start + perPage);
        tbody.innerHTML = '';

        pageItems.forEach((p, i) => {
            const sc = p.score >= 70 ? 'score-high' : p.score >= 50 ? 'score-mid' : 'score-low';
            const signalClass = p.score >= 70 ? 'tag-buy' : p.score >= 40 ? 'tag-hold' : 'tag-sell';
            const signalText = p.score >= 70 ? '🟢 买入' : p.score >= 40 ? '🟡 观望' : '🔴 卖出';
            const f = p.features || {};
            const tr = document.createElement('tr');
            tr.style.animationDelay = `${i * 0.03}s`;
            tr.dataset.code = p.code || '';
            tr.dataset.name = p.name || p.code || '';
            tr.dataset.score = p.score || 0;
            tr.dataset.close = p.close || 0;
            tr.dataset.pctChg = f.pct_chg || p.pct_chg || 0;
            tr.onclick = () => openStockModal(p.code || '', p.name || p.code || '', p.score || 0, p.close || 0, f.pct_chg || p.pct_chg || 0);
            tr.innerHTML = `
                <td class="rank">${start + i + 1}</td>
                <td><span class="stock-name">${p.name || p.code}</span></td>
                <td><span class="stock-code">${p.code || ''}</span></td>
                <td class="${sc}">${p.score}</td>
                <td><span class="tag ${signalClass}">${signalText}</span></td>
                <td>${(p.close || 0).toFixed(2)}</td>
                <td style="color:${(f.pct_chg || p.pct_chg || 0) >= 0 ? 'var(--success)' : 'var(--danger)'}">${(f.pct_chg || p.pct_chg || 0).toFixed(2)}%</td>
                <td>${(f.rsi6 || 50).toFixed(1)}</td>
                <td>${(f.k || 50).toFixed(1)}</td>
                <td>${(f.d || 50).toFixed(1)}</td>
            `;
            tbody.appendChild(tr);
        });

        renderPager('minute-pager', currentPage, totalPages, total, (page) => {
            sessionStorage.setItem('minute_page', String(page));
            renderMinute(predictions);
        });
    }

