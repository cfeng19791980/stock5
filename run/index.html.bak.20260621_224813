    // ===== K线数据加载 =====
    function loadKlineData(code) {
        const selectedCode = code || document.getElementById('klineSelector').value;
        
        // 优先尝试获取个股数据，如果没有则用大盘指数
        fetch(`/api/kline/${selectedCode}`)
            .then(r => r.json())
            .then(d => {
                if (d.kline && d.kline.length > 0) {
                    renderKline(d.kline);
                } else {
                    // 没有个股数据，加载大盘指数
                    loadMarketIndex();
                }
            })
            .catch(() => {
                loadMarketIndex();
            });
    }

    function loadMarketIndex() {
        fetch('/api/market_index')
            .then(r => r.json())
            .then(d => {
                if (d.kline && d.kline.length > 0) {
                    document.getElementById('klineSelector').value = d.code;
                    renderKline(d.kline);
                }
            })
            .catch(() => {
                // 如果都失败，回退到评分条形图
                updateKlineFallback();
            });
    }

    function renderKline(klineData) {
        if (!klineChart || !klineData || klineData.length === 0) return;

        const dates = klineData.map(k => k.date);
        const ohlc = klineData.map(k => [k.open, k.close, k.low, k.high]);

        klineChart.setOption({
            xAxis: { data: dates, type: 'category' },
            yAxis: [{ type: 'value', scale: true }],
            series: [{ type: 'candlestick', data: ohlc }]
        }, { notMerge: false });
        klineChart.resize();
    }

    function updateKlineFallback() {
        // 回退到原来的评分条形图
        if (minuteData && minuteData.length > 0 && klineChart) {
            const top20 = [...minuteData].sort((a,b) => b.score - a.score).slice(0, 20);
            const topNames = top20.map(p => (p.name || p.code || '').substring(0, 6));
            const topScores = top20.map(p => p.score);
            const topColors = top20.map(p => p.score >= 70 ? '#10b981' : p.score >= 50 ? '#8b5cf6' : '#ef4444');

            klineChart.setOption({
                xAxis: { data: topNames, type: 'category' },
                yAxis: [{ type: 'value', scale: true }],
                series: [{
                    type: 'bar',
                    data: topScores.map((v, i) => ({
                        value: v,
                        itemStyle: { color: topColors[i], borderRadius: [3, 3, 0, 0] }
                    })),
                    barWidth: '50%'
                }]
            }, { notMerge: false });
            klineChart.resize();
        }
    }

    function changeKline() {
        loadKlineData();
    }

    function updateCharts() {
        // 评分分布 - 只用日线数据
        const dailyScores = [];
        (dailyData || []).forEach(s => dailyScores.push(s.score));

        // Update kline chart - use minute data prices as line chart
        if (minuteData && minuteData.length > 0 && klineChart) {
            const sorted = [...minuteData].sort((a, b) => (a.code || '').localeCompare(b.code || ''));
            const names = sorted.map(p => (p.name || p.code || '').substring(0, 6));
            const prices = sorted.map(p => p.close || 0);

            // Show top 20 by score as a bar chart of scores
            const top20 = [...minuteData].sort((a,b) => b.score - a.score).slice(0, 20);
            const topNames = top20.map(p => (p.name || p.code || '').substring(0, 6));
            const topScores = top20.map(p => p.score);
            const topColors = top20.map(p => p.score >= 70 ? '#10b981' : p.score >= 50 ? '#8b5cf6' : '#ef4444');

            klineChart.setOption({
                xAxis: { data: topNames },
                series: [{
                    type: 'bar',
                    data: topScores.map((v, i) => ({
                        value: v,
                        itemStyle: { color: topColors[i], borderRadius: [3, 3, 0, 0] }
                    })),
                    barWidth: '50%',
                    smooth: false,
                    areaStyle: null,
                    symbol: 'none',
                    lineStyle: null
                }]
            });
        }
    }

