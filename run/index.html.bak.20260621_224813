    function startCollection() {
        fetch(`${API_BASE}/start_collection`, {method: 'POST'})
            .then(r => r.json())
            .then(d => { if(d.success) { checkCollection(); } else { alert(d.message); }})
            .catch(e => alert('启动失败: ' + e.message));
    }
    function stopCollection() {
        fetch(`${API_BASE}/stop_collection`, {method: 'POST'})
            .then(r => r.json())
            .then(d => { if(d.success) checkCollection(); })
            .catch(e => alert('停止失败: ' + e.message));
    }
    function checkCollection() {
        fetch(`${API_BASE}/status`)
            .then(r => r.json())
            .then(d => {
                const running = d.collection_running;
                const chip = document.getElementById('collectionChip');
                const chipText = document.getElementById('collectionChipText');
                const sidebarStatus = document.getElementById('sidebarStatus');
                const sidebarText = document.getElementById('sidebarStatusText');
                if (running) {
                    chip.classList.add('running');
                    chipText.textContent = '运行中';
                    sidebarStatus.classList.add('running');
                    sidebarText.textContent = '运行中';
                    document.getElementById('collectionStatus').textContent = '运行中';
                    setRing('ringCollection', 100, 'ON', 'var(--success)');
                } else {
                    chip.classList.remove('running');
                    chipText.textContent = '未运行';
                    sidebarStatus.classList.remove('running');
                    sidebarText.textContent = '未运行';
                    document.getElementById('collectionStatus').textContent = '未运行';
                    setRing('ringCollection', 0, 'OFF', 'var(--danger)');
                }
            }).catch(() => {});
    }

