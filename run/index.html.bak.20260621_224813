<script>
    // ===== State =====
    let refreshTimer = null;
    let currentTab = 'minute';
    let klineChart = null;
    let minuteData = [];
    let dailyData = [];

    // ===== Init =====
    loadAll();
    startAutoRefresh();
    updateClock();
    setInterval(updateClock, 1000);
    setInterval(checkCollection, 10000);

    // Init ECharts
    window.addEventListener('load', () => {
        initCharts();
    });

    // ===== Utility =====
    function updateClock() {
        const now = new Date();
        document.getElementById('currentTime').textContent = now.toLocaleTimeString('zh-CN', { hour12: false });
    }

    function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('open');
        document.getElementById('sidebarOverlay').classList.toggle('show');
    }

    function startAutoRefresh() {
        // 定时预测（每1小时，不等待结果）
        setInterval(() => {
            fetch('/api/run_predict', {method: 'POST'}).catch(()=>{});
        }, 3600000);  // 1小时
        
        // 定时读取数据（每10分钟）
        setInterval(loadAll, 600000);
    }

    function switchTab(tab) {
        currentTab = tab;
        document.querySelectorAll('.tab-btn').forEach(t => t.classList.remove('active'));
        document.querySelector(`.tab-btn[data-tab="${tab}"]`).classList.add('active');
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        document.getElementById(`tab-${tab}`).classList.add('active');
    }

    async function loadJson(url) {
        try {
            const r = await fetch(url + '?t=' + Date.now());
            if (!r.ok) return null;
            return await r.json();
        } catch(e) {
            return null;
        }
    }

    // ===== Ring Chart Animation =====
    const CIRCUMFERENCE = 2 * Math.PI * 30; // ~188.5

    // ===== 环形图颜色 =====
    function getScoreColor(score) {
        if (score >= 80) return 'var(--success)';   // 绿 - 强势
        if (score >= 60) return 'var(--primary)';   // 蓝 - 正常
        if (score >= 40) return 'var(--warning)';   // 橙 - 警惕
        return 'var(--danger)';                     // 红 - 危险
    }

    function setRing(chartId, percent, label, color) {
        const el = document.getElementById(chartId);
        if (!el) return;
        const fill = el.querySelector('.ring-fill');
        const lbl = el.querySelector('.ring-label');
        
        // 自动根据数值变色（支持数字和百分比）
        let autoColor = color;
        if (typeof label === 'number') {
            autoColor = getScoreColor(label);
        } else if (typeof label === 'string' && /^\d+$/.test(label)) {
            autoColor = getScoreColor(parseInt(label));
        }
        
        if (fill) {
            fill.setAttribute('stroke', autoColor || color || 'var(--primary)');
            const offset = CIRCUMFERENCE - (percent / 100) * CIRCUMFERENCE;
            fill.setAttribute('stroke-dashoffset', offset);
        }
        if (lbl) lbl.textContent = label;
    }

    // ===== 数字滚动动画 =====
    function animateValue(element, start, end, duration = 1000) {
        if (!element) return;
        const startTime = performance.now();
        const isFloat = String(end).includes('.');
        
        function update(currentTime) {
            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);
            // easeOutCubic
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = start + (end - start) * eased;
            
            element.textContent = isFloat ? current.toFixed(1) : Math.round(current);
            
            if (progress < 1) {
                requestAnimationFrame(update);
            }
        }
        requestAnimationFrame(update);
    }

    // ===== 告警通知 =====
    let prevBuyStocks = []; // 之前买入信号的股票列表
    
    function checkBuyAlerts(dailyBody, stocks) {
        // 获取当前买入信号的股票
        const currentBuys = [];
        stocks.forEach(s => {
            if (s.buy_signal) {
                currentBuys.push(s.code || s.name);
            }
        });
        
        // 检测新股民买信号
        const newBuys = currentBuys.filter(c => !prevBuyStocks.includes(c));
        
        if (newBuys.length > 0) {
            // 弹窗通知
            showNotification(`🔔 发现 ${newBuys.length} 个新买入信号: ${newBuys.join(', ')}`, 'buy');
            // 播放提示音
            playAlertSound();
        }
        
        prevBuyStocks = currentBuys;
    }
    
    function showNotification(message, type) {
        // 创建通知元素
        const notif = document.createElement('div');
        notif.style.cssText = `
            position: fixed; bottom: 20px; right: 20px;
            background: ${type === 'buy' ? 'var(--success)' : 'var(--warning)'};
            color: #fff; padding: 14px 20px; border-radius: 10px;
            font-size: 13px; font-weight: 600; z-index: 9999;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            animation: slideInRight 0.3s ease-out;
            max-width: 320px; word-wrap: break-word;
        `;
        notif.textContent = message;
        
        // 添加动画样式
        const style = document.createElement('style');
        style.textContent = `@keyframes slideInRight {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }`;
        document.head.appendChild(style);
        document.body.appendChild(notif);
        
        // 5秒后自动关闭
        setTimeout(() => {
            notif.style.animation = 'fadeOut 0.3s ease-out forwards';
            setTimeout(() => notif.remove(), 300);
        }, 5000);
    }
    
    function playAlertSound() {
        try {
            const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            
            oscillator.frequency.value = 880;
            oscillator.type = 'sine';
            gainNode.gain.setValueAtTime(0.3, audioCtx.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.5);
            
            oscillator.start(audioCtx.currentTime);
            oscillator.stop(audioCtx.currentTime + 0.5);
        } catch(e) {
            console.log('播放提示音失败:', e);
        }
    }

    // ===== Load Data =====
    let prevBuySignals = 0;

    async function loadAll() {
        // 直接读取数据（预测单独定时触发）
        await Promise.all([loadMinute(), loadDaily()]);

        // 买入信号 - 带动画
        const dailyBody = document.getElementById('body-daily');
        let dailyBuys = 0;
        if (dailyBody) {
            dailyBuys = dailyBody.querySelectorAll('.tag-buy').length;
        }
