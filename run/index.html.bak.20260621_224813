    }

    function closeStockModal() {
        document.getElementById('stockModal').classList.remove('show');
    }

    async function loadModalKline(code) {
        try {
            const statusEl = document.getElementById('modalKlineStatus');
            console.log('[loadModalKline] 开始加载, code:', code);
            statusEl.textContent = '正在加载 ' + code + ' ...';
            
            if (!modalKlineChart) {
                console.error('[loadModalKline] modalKlineChart 未初始化');
                statusEl.textContent = '图表未初始化';
                return;
            }
            
            modalKlineChart.showLoading({ text: '加载中...', color: '#3b82f6' });
            
            const url = '/api/kline/' + code;
            console.log('[loadModalKline] 请求URL:', url);
            statusEl.textContent = '请求: ' + url;
            
            const r = await fetch(url);
            console.log('[loadModalKline] 响应状态:', r.status);
            statusEl.textContent = '响应状态: ' + r.status;
            
            const d = await r.json();
            console.log('[loadModalKline] 数据:', d.kline?.length, '条, source:', d.source);
            statusEl.textContent = '数据: ' + (d.kline ? d.kline.length + '条' : '空') + ' source:' + d.source;
            
            if (d.kline && d.kline.length > 0) {
                modalKlineChart.hideLoading();
                renderModalKline(d.kline);
                statusEl.style.display = 'none';
            } else {
                statusEl.textContent = '无数据: ' + code + ' (source:' + d.source + ')';
                modalKlineChart.hideLoading();
                modalKlineChart.setOption({
                    title: { text: '暂无K线数据', left: 'center', top: 'center', textStyle: { color: '#64748b' } },
                    series: []
                });
            }
        } catch(e) {
            console.error('[loadModalKline] 错误:', e);
            const statusEl = document.getElementById('modalKlineStatus');
            statusEl.textContent = '错误: ' + e.message;
            if (modalKlineChart) {
                modalKlineChart.hideLoading();
                modalKlineChart.setOption({
                    title: { text: '数据加载失败: ' + e.message, left: 'center', top: 'center', textStyle: { color: '#ef4444' } },
                    series: []
                });
            }
        }
    }

    function renderModalKline(klineData) {
        if (!modalKlineChart) return;
        
        const dates = klineData.map(k => k.date);
        const ohlc = klineData.map(k => [k.open, k.close, k.low, k.high]);
        
        modalKlineChart.setOption({
            backgroundColor: 'transparent',
            grid: { top: 30, right: 50, bottom: 60, left: 50 },
            tooltip: {
                trigger: 'axis',
                axisPointer: { type: 'cross' },
                backgroundColor: '#1e293b',
                borderColor: '#334155',
                textStyle: { color: '#f1f5f9' }
            },
            xAxis: {
                type: 'category',
                data: dates,
                axisLine: { lineStyle: { color: '#334155' } },
                axisLabel: { color: '#64748b', fontSize: 10, rotate: 45 }
            },
            yAxis: [
                {
                    type: 'value',
                    scale: true,
                    splitLine: { lineStyle: { color: '#1e293b' } },
                    axisLabel: { color: '#64748b', fontSize: 10 }
                }
            ],
            dataZoom: [
                { type: 'inside', start: 50, end: 100 },
                { type: 'slider', start: 50, end: 100, height: 20, bottom: 30 }
            ],
            series: [{
                type: 'candlestick',
                data: ohlc,
                itemStyle: {
                    color: '#ef4444',
                    color0: '#10b981',
                    borderColor: '#ef4444',
                    borderColor0: '#10b981'
                }
            }]
        });
        modalKlineChart.resize();
    }

    // ===== 自选股功能 =====
    let watchlist = JSON.parse(localStorage.getItem('stock5_watchlist') || '[]');
    let account = { total_cash: 100000, available_cash: 100000 };

    // 同步持仓到后端
    async function syncHoldingsToFile() {
        const holdings = watchlist.map(item => ({
            code: item.code,
            name: item.name || item.code,
            buyPrice: item.buyPrice || 0,
            buyQty: item.buyQty || 0,
            entryDate: new Date(item.addedAt || Date.now()).toISOString().slice(0, 10),
        }));
        try { await fetch('/api/save_holdings', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(holdings)}); } catch(e) {}
    }

    // 同步资金到后端
    async function syncAccountToFile() {
        account.total_cash = parseFloat(document.getElementById('totalCashInput').value) || account.total_cash || 100000;
        account.available_cash = account.total_cash;
        localStorage.setItem('stock5_account', JSON.stringify(account));
        try { await fetch('/api/save_account', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(account)}); } catch(e) {}
    }

    // 初始化账户：localStorage 优先，推送到后端
    async function initAccount() {
        const savedCash = localStorage.getItem('stock5_account');
        if (savedCash) account = JSON.parse(savedCash);
        try {
            const r = await fetch('/api/get_account');
            if (r.ok) {
                const fa = await r.json();
                if (fa.total_cash > 0) account.total_cash = fa.total_cash;
            }
        } catch(e) {}
        document.getElementById('totalCashInput').value = account.total_cash || 100000;
        updateAccountDisplay();
        renderWatchlist();
        syncHoldingsToFile();
        syncAccountToFile();
    }

    function updateAccountDisplay() {
        const totalCash = parseFloat(document.getElementById('totalCashInput').value) || 100000;
        let positionValue = 0;
        let positionCost = 0;
        const allData = [...minuteData, ...dailyData];
        watchlist.forEach(item => {
            const itemNum = (item.code || '').replace(/[^0-9]/g, '');
            const stock = allData.find(s => ((s.code || '') + '').replace(/[^0-9]/g, '') === itemNum);
            const qty = item.buyQty || 0;
            if (stock && stock.close) {
                positionValue += qty * stock.close;
            }
            positionCost += (item.buyPrice || 0) * qty;
        });
        const availableCash = totalCash - positionCost;
        document.getElementById('positionValueDisplay').textContent = '持仓市值: ' + positionValue.toLocaleString();
        document.getElementById('availableCashDisplay').textContent = '可用资金: ' + Math.max(0, availableCash).toLocaleString();
    }

    async function saveAccount() {
        await syncAccountToFile();
        updateAccountDisplay();
    }

    // 监听资金输入变化
    document.addEventListener('DOMContentLoaded', () => {
        setTimeout(initAccount, 500);
        setTimeout(() => {
            const cashInput = document.getElementById('totalCashInput');
            if (cashInput) cashInput.addEventListener('input', updateAccountDisplay);
        }, 600);
    });

    // Sidebar版本 - 不再使用右侧滑出面板
    function toggleWatchlist() {
        // 保留原函数兼容性，但实际功能已移至Sidebar
    }
    
    function toggleWatchlistInSidebar() {
        document.getElementById('watchlistInput').focus();
    }
    
    function handleWatchlistKeypress(event) {
        if (event.key === 'Enter') {
            addToWatchlist();
        }
    }

    function addToWatchlist() {
        const input = document.getElementById('watchlistInput');
        const priceInput = document.getElementById('watchlistPrice');
        const qtyInput = document.getElementById('watchlistQty');
        
        // 支持多种格式: 600519, 600519.SH, sh.600519
        let code = input.value.trim().toUpperCase();
        if (!code) return;
        
        // 标准化股票代码
        code = code.replace(/^(SH|SZ)\./, '').replace(/\.SH$|\.SZ$/, '');
        if (!code.match(/^[0-9]{6}$/)) {
            // 尝试提取数字部分
            const numMatch = code.match(/[0-9]{6}/);
            if (numMatch) {
                code = numMatch[0];
            } else {
                alert('请输入有效的6位股票代码');
                return;
            }
        }
        
        // 智能判断交易所后缀
        const num = parseInt(code);
        if (num >= 600000 || num === 688) {
            code = code + '.SH';
        } else {
            code = code + '.SZ';
        }
        
        // 获取买入价格和数量
        const buyPrice = parseFloat(priceInput.value) || 0;
        const buyQty = parseInt(qtyInput.value) || 0;
        
        if (!watchlist.find(s => s.code === code)) {
            watchlist.push({ code, name: code.split('.')[0], buyPrice, buyQty, addedAt: Date.now() });
            localStorage.setItem('stock5_watchlist', JSON.stringify(watchlist));
            syncHoldingsToFile();
            renderWatchlist();
            updateAccountDisplay();
        }
        input.value = '';
        priceInput.value = '';
        qtyInput.value = '';
    }

    function removeFromWatchlist(code) {
        watchlist = watchlist.filter(s => s.code !== code);
        localStorage.setItem('stock5_watchlist', JSON.stringify(watchlist));
        syncHoldingsToFile();
        renderWatchlist();
        updateAccountDisplay();
    }

    function renderWatchlist() {
        const container = document.getElementById('watchlistItems');
        const countEl = document.getElementById('watchlistCount');
        
        // 更新计数
        if (countEl) countEl.textContent = watchlist.length + '只';
        
        if (watchlist.length === 0) {
            container.innerHTML = '<div class="watchlist-empty"><i class="fas fa-star" style="font-size:20px;margin-bottom:8px;opacity:0.3;"></i><p style="font-size:12px;">暂无自选</p></div>';
            return;
        }
        
        // 从 minuteData/dailyData 查找匹配的数据
        const allData = [...minuteData, ...dailyData];
        
        container.innerHTML = watchlist.map(item => {
            // 用数字部分匹配
            const itemNum = (item.code || '').replace(/[^0-9]/g, '');
            const stock = allData.find(s => ((s.code || '') + '').replace(/[^0-9]/g, '') === itemNum);
            const score = stock ? stock.score : null;
            const name = stock ? (stock.name || item.code) : item.code.split('.')[0];
            const close = stock ? (stock.close || stock.features?.close) : null;
            const pct_chg = stock ? (stock.pct_chg || stock.features?.pct_chg) : null;
            
            // 评分颜色
            let scoreClass = 'medium';
            let scoreColor = 'var(--warning)';
            if (score !== null) {
                if (score >= 70) { scoreClass = 'high'; scoreColor = 'var(--success)'; }
                else if (score < 50) { scoreClass = ''; scoreColor = 'var(--danger)'; }
            }
            
            // 涨跌颜色
            const changeColor = pct_chg != null ? (pct_chg >= 0 ? 'var(--success)' : 'var(--danger)') : 'var(--text-muted)';
            const changeText = pct_chg != null ? (pct_chg >= 0 ? '+' : '') + pct_chg.toFixed(2) + '%' : '--';
            
            // 盈亏计算
            const buyPrice = item.buyPrice || 0;
            const buyQty = item.buyQty || 0;
            let profitText = '', profitColor = 'var(--text-muted)';
            if (buyPrice > 0 && buyQty > 0 && close) {
                const profitAmt = (close - buyPrice) * buyQty;
                const profit = (close - buyPrice) / buyPrice * 100;
                profitText = (profitAmt >= 0 ? '+' : '') + profitAmt.toFixed(0) + ' (' + (profit >= 0 ? '+' : '') + profit.toFixed(1) + '%)';
                profitColor = profitAmt >= 0 ? 'var(--success)' : 'var(--danger)';
            }
            
            return `
                <div class="watchlist-item" onclick="openStockModal('${item.code}', '${name}', ${score !== null ? score : 'null'}, ${close !== null ? close.toFixed(2) : 'null'}, ${pct_chg != null ? pct_chg.toFixed(2) : 'null'})">
                    <div style="flex:1;min-width:0;">
                        <div class="stock-name" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                            ${name}
                            ${profitText ? `<span style="font-size:10px;color:${profitColor};margin-left:4px;">${profitText}</span>` : ''}
                        </div>
                        <div class="stock-code" style="font-size:10px;">${item.code} ${buyPrice>0?'成本:'+buyPrice.toFixed(2):''}</div>
                    </div>
                    <div style="text-align:right;flex-shrink:0;margin-left:8px;">
                        <div style="font-size:14px;font-weight:700;color:var(--text-primary);">${close?close.toFixed(2):'--'}</div>
                        <div style="font-size:11px;color:${changeColor};">${changeText}</div>
                        <div style="font-size:10px;color:${scoreColor};font-weight:600;">评分 ${score!==null?score:'--'}</div>
                        <button class="delete-btn" onclick="event.stopPropagation();removeFromWatchlist('${item.code}')">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
            `;
        }).join('');
    }

    // ===== 表格行点击事件 =====
    function setupTableClickHandlers() {
        // 分钟线表格
        document.querySelectorAll('#body-minute tr').forEach(tr => {
            tr.addEventListener('click', () => {
                const code = tr.dataset.code;
                const name = tr.dataset.name;
                const score = parseInt(tr.dataset.score);
                const close = parseFloat(tr.dataset.close);
                const pct_chg = parseFloat(tr.dataset.pctChg);
                if (code) openStockModal(code, name, score, close, pct_chg);
            });
        });
        
        // 日线表格
        document.querySelectorAll('#body-daily tr').forEach(tr => {
            tr.addEventListener('click', () => {
                const code = tr.dataset.code;
                const name = tr.dataset.name;
                const score = parseInt(tr.dataset.score);
                const close = parseFloat(tr.dataset.close);
                const pct_chg = parseFloat(tr.dataset.pctChg);
                if (code) openStockModal(code, name, score, close, pct_chg);
            });
        });
    }

    // 初始化自选股列表
    renderWatchlist();

    // 点击弹窗外部关闭
    document.getElementById('stockModal').addEventListener('click', function(e) {
        if (e.target === this) closeStockModal();
    });
</script>
