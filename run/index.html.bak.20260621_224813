        html += '<div class="strategy-stats">';
        html += '<div class="strategy-stat"><div class="strategy-stat-value" style="color:var(--primary);">'+(pf.total_cash/10000).toFixed(1)+'万</div><div class="strategy-stat-label">总资金</div></div>';
        html += '<div class="strategy-stat"><div class="strategy-stat-value" style="color:var(--success);">'+(pf.position_value/10000).toFixed(1)+'万</div><div class="strategy-stat-label">持仓市值</div></div>';
        html += '<div class="strategy-stat"><div class="strategy-stat-value" style="color:var(--warning);">'+(cash/10000).toFixed(1)+'万</div><div class="strategy-stat-label">现金</div></div>';
        html += '<div class="strategy-stat"><div class="strategy-stat-value">'+(pf.holding_count||0)+'</div><div class="strategy-stat-label">持仓数</div></div>';
