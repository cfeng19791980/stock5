    // ===== 交易策略 =====
    async function runStrategy() {
        const container = document.getElementById('strategyContainer');
        container.innerHTML = '<div class="strategy-loading"><i class="fas fa-spinner fa-spin"></i> 生成策略中...</div>';
        // 确保数据已落盘
        await syncAccountToFile();
        await syncHoldingsToFile();
        // 调用后端运行策略引擎
        try {
            const result = await (await fetch('/api/run_strategy', {method:'POST'})).json();
            if (result.success) {
                renderStrategy(result.data);
                return;
            }
        } catch(e) {}
        // 降级：读本地 strategy_signals.json
        try {
            const resp = await fetch('./strategy_signals.json?' + Date.now());
            const data = await resp.json();
            renderStrategy(data);
        } catch (e) {
            container.innerHTML = '<div class="strategy-loading"><i class="fas fa-exclamation-triangle"></i> 请先启动 web_server.py，然后点击刷新</div>';
        }
    }

    async function loadStrategy() { runStrategy(); }

    function renderStrategy(data) {
        const container = document.getElementById('strategyContainer');
